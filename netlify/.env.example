# Netlify Functions Environment Variables
# Copy this file to .env and update the values

# Database connection string
# Get this from your database provider (Neon, Supabase, Railway, etc.)
# Example format: postgresql://username:password@host:5432/database?sslmode=require
DATABASE_URL=your_database_connection_string_here

# Cookie signing secret for article subscriber sessions
SESSION_SECRET=replace_me_with_a_long_random_string

# Resend configuration for one-time sign-in codes
RESEND_API_KEY=re_xxxxx
RESEND_FROM_NAME=AI Recap
RESEND_FROM_EMAIL=login@updates.airecap.news

# GHL webhook used for native article-gate subscriptions
GHL_SUBSCRIBE_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...
