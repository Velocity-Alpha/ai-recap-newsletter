# Next.js Environment Variables
# Copy this file to .env.local and update the values

# Site URL used for OpenGraph metadataBase (no trailing slash)
# NEXT_PUBLIC_SITE_URL=https://airecap.news

# Optional Google Analytics measurement ID for local testing only.
# Leave unset in local development unless you intentionally want to send data to a non-production GA property.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-8GQC9DS1S7

# Server-side database connection for newsletter reads, article gating, and OTP flows.
# DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# Optional separate production database URL for `npm run prisma:migrate:prod:*` commands.
# PRODUCTION_DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# Optional runtime database role name for grant/bootstrap scripts.
# NEWSLETTER_RUNTIME_DB_ROLE=newsletter_web

# Cookie signing secret for subscriber sessions.
# SESSION_SECRET=replace_me_with_a_long_random_string

# Resend configuration for OTP emails.
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM_NAME=AI Recap
# RESEND_FROM_EMAIL=login@updates.airecap.news

# Beehiiv configuration for newsletter subscriptions.
# BEEHIIV_API_KEY=your_beehiiv_api_key
# BEEHIIV_PUBLICATION_ID=pub_xxxxx



# Optional override for the for-brands webhook destination.
# FOR_BRANDS_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...

